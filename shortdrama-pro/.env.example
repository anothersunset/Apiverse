# 运行模式：local / hybrid / production
RUN_MODE=production

# LLM：剧情、角色、分镜
LLM_PROVIDER=openai
OPENAI_API_KEY=填写你的 OpenAI Key
DEEPSEEK_API_KEY=可选
ANTHROPIC_API_KEY=可选

# 图像：角色图、首帧图
IMAGE_PROVIDER=comfyui
COMFYUI_BASE_URL=http://127.0.0.1:8188
MIDJOURNEY_API_KEY=可选

# 视频：镜头片段
VIDEO_PROVIDER=kling
KLING_API_KEY=填写你的 Kling Key
VEO_API_KEY=可选
RUNWAY_API_KEY=可选

# 配音
VOICE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=填写你的 ElevenLabs Key
MINIMAX_API_KEY=可选
AZURE_SPEECH_KEY=可选

# 合成
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
FPS=24
DEFAULT_SHOT_SECONDS=6
