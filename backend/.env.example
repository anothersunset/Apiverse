# === 基础 ===
PORT=5000
MONGODB_URI=                   # 留空 = 走内存模式
REDIS_URL=redis://127.0.0.1:6379
STORAGE_ROOT=./storage
PUBLIC_BASE_URL=http://localhost:5000

# === Provider 开关（默认全 mock，零成本验证）===
SCRIPT_PROVIDER=mock           # mock | openai | claude
CHARACTER_PROVIDER=mock        # mock | flux | comfyui | mj
VIDEO_PROVIDER=mock            # mock | kling | veo | runway
VOICE_PROVIDER=mock            # mock | elevenlabs | edgetts

# === OpenAI / Claude ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# === Kling（可灵）===
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api.klingai.com

# === Google Veo / Runway ===
VEO_API_KEY=
RUNWAY_API_KEY=

# === Flux / Replicate / fal ===
REPLICATE_API_TOKEN=
FAL_KEY=

# === ComfyUI（本地）===
COMFYUI_BASE_URL=http://127.0.0.1:8188

# === ElevenLabs ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# === 并发限制 ===
SHOT_CONCURRENCY=2
VOICE_CONCURRENCY=3
